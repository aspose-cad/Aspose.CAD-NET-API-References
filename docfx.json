{
  "globalMetadata": {
    "_appTitle": "Aspose.CAD API",
    "_appFooter": "Copyright © Aspose",
    "_disableContribution": true,
    "_enableSearch": "true"
  },
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/*.dll"
          ]
        }
      ],
      "dest": "api",
	  
      "noRestore": false,
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
	  "namespaceLayout": "nested",
	  "memberLayout": "separatePages"
    }
  ],
  "build": {
	"sitemap":{
      "baseUrl": "https://reference.aspose.com/cad/net",
      "priority": 0.3,
      "changefreq": "monthly",
      "fileOptions":{
          "**/api/**.yml": {
              "priority": 0.8,
              "lastmod": "2023-06-01",
              "changefreq": "weekly"
          }
      }
    },
    "content": [
      {
        "files": [
          "api/**.yml"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      }
    ],
	"resource": [
      {
        "files": [
          "logo.svg",
          "favicon.ico",
		  "images/**"
        ]
      }
    ],
    "overwrite": [
      {
        "files": [
          "apidoc/**.md"
        ],
        "exclude": [
          "obj/**",
          "_site/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default"
    ],
    "postProcessors": [
	  "ExtractSearchIndex"
	],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}